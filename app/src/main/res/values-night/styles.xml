<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Radioto" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Couleurs primaires -->
        <!-- Ces items vont maintenant chercher les couleurs définies dans values-night/colors.xml -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorOnPrimary">@color/on_primary_color</item>
        <item name="colorPrimaryContainer">@color/primary_container_color</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container_color</item>

        <!-- Couleurs secondaires -->
        <item name="colorSecondary">@color/teal_secondary</item>
        <item name="colorOnSecondary">@color/on_secondary_color</item>
        <item name="colorSecondaryContainer">@color/secondary_container_color</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container_color</item>

        <!-- Couleurs d'erreur -->
        <item name="colorError">@color/red_error</item>
        <item name="colorOnError">@color/on_error_color</item>
        <item name="colorErrorContainer">@color/error_container_color</item>
        <item name="colorOnErrorContainer">@color/on_error_container_color</item>

        <!-- Couleurs de fond et de surface -->
        <item name="android:colorBackground">@color/app_background</item>
        <item name="colorOnBackground">@color/on_background_color</item>
        <item name="colorSurface">@color/surface_color</item>
        <item name="colorOnSurface">@color/on_surface_color</item>
        <item name="colorSurfaceVariant">@color/surface_variant_color</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_color</item>

        <!-- Couleurs des contours -->
        <item name="colorOutline">@color/outline_color</item>
        <item name="colorOutlineVariant">@color/outline_variant_color</item>

        <!-- Personnalisation de la barre d'état pour le MODE NUIT -->
        <!-- ?attr/colorSurface prendra la valeur de colorSurface du mode nuit -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorSurface</item>
        <!-- false pour que les icônes de la barre d'état soient claires sur un fond sombre -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

</resources>